# Server
PORT=4000
NODE_ENV=production
# Panel + desarrollo local
CORS_ORIGIN=https://matuhost.com,http://localhost:3000,http://127.0.0.1:3000

# MatuDB — ver MATUDB.md.txt
MATUDB_URL=https://db.matudb.com
MATUDB_PROJECT_ID=tu-project-id
MATUDB_API_KEY=mb_tu_clave
MATUDB_USE_SUPABASE=false

# IP pública del VPS
DEFAULT_SERVER_IP=187.124.241.122

# Nginx + sitios (producción)
NGINX_VHOSTS_DIR=/etc/nginx/sites-available
NGINX_SITES_ENABLED_DIR=/etc/nginx/sites-enabled
DEFAULT_DOCUMENT_ROOT=/var/www/matuhost
NGINX_RELOAD_CMD=sudo nginx -t && sudo systemctl reload nginx

# DNS autoritativo BIND9
DNS_ZONES_DIR=/etc/bind/zones/matuhost
DNS_NAMED_CONF_SNIPPET=/etc/bind/matuhost-zones.conf
DNS_SERVER_IP=187.124.241.122
MATUHOST_NS1=ns1.matuhost.com
MATUHOST_NS2=ns2.matuhost.com
DNS_ADMIN_EMAIL=hostmaster.matuhost.com
DNS_RELOAD_CMD=sudo rndc reload

# Zona padre (glue + delegación subdominios plataforma)
PLATFORM_PARENT_ZONE=matuhost.com
PLATFORM_PARENT_ZONE_FILE=/etc/bind/zones/matuhost/db.matuhost_com
PLATFORM_APEX_DOMAIN=hosts.matuhost.com

# Apex externos: API registrador (landatech.ai, etc.)
# REGISTRAR_API_URL=https://api.tu-registrador.com/v1
# REGISTRAR_API_KEY=
# REGISTRAR_PUBLISH_MODE=both
# REGISTRAR_API_NS_PATH=/domains/{fqdn}/nameservers
# REGISTRAR_API_A_PATH=/domains/{fqdn}/dns
MATUHOST_NS_MODE=platform

# CERTBOT_CMD=sudo certbot certonly --nginx -d {fqdn} --non-interactive --agree-tos -m admin@matuhost.com
