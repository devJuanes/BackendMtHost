# Server
PORT=4000
NODE_ENV=development
# Producción: URL(s) del panel, separadas por coma
CORS_ORIGIN=http://localhost:3000

# MatuDB (matu-db-api) — ver MATUDB.md.txt
MATUDB_URL=https://db.matudb.com
MATUDB_PROJECT_ID=tu-project-id
MATUDB_API_KEY=mb_tu_clave
MATUDB_USE_SUPABASE=false

# Hosting / Nginx (paths on your VPS)
NGINX_VHOSTS_DIR=./data/nginx/sites-available
NGINX_SITES_ENABLED_DIR=./data/nginx/sites-enabled
# Producción: IP pública del VPS
DEFAULT_SERVER_IP=127.0.0.1
# Producción: /var/www/matuhost
DEFAULT_DOCUMENT_ROOT=./data/www

# DNS autoritativo MatuHost (BIND9)
DNS_ZONES_DIR=/etc/bind/zones/matuhost
DNS_NAMED_CONF_SNIPPET=/etc/bind/matuhost-zones.conf
DNS_SERVER_IP=187.124.241.122
MATUHOST_NS1=ns1.matuhost.com
MATUHOST_NS2=ns2.matuhost.com
DNS_ADMIN_EMAIL=hostmaster.matuhost.com
DNS_RELOAD_CMD=sudo rndc reload
NGINX_RELOAD_CMD=sudo nginx -t && sudo systemctl reload nginx
# CERTBOT_CMD=sudo certbot certonly --nginx -d {fqdn} --non-interactive --agree-tos -m admin@matuhost.com

# Registro corto: "miweb" → miweb.hosts.matuhost.com (DNS 100% plataforma)
# PLATFORM_APEX_DOMAIN=hosts.matuhost.com
