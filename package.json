{
  "name": "matuhost-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/kill-port.mjs 4000",
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "dev:restart": "node scripts/kill-port.mjs 4000 && tsx watch --clear-screen=false src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:dns": "tsx src/db/migrate-dns.ts",
    "db:sync-users": "tsx src/db/sync-users.ts",
    "dns:sync": "tsx src/db/sync-dns-zones.ts",
    "sites:default": "tsx src/db/provision-default-sites.ts"
  },
  "dependencies": {
    "@devjuanes/matuclient": "^2.2.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
